APP_NAME=PyPath Backend API
APP_VERSION=1.1.0
APP_DESCRIPTION=Production-ready FastAPI backend for PyPath
DEBUG=false

API_PREFIX=
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./pypath.db
JWT_SECRET_KEY=change-me-please

# Для списка CORS можно передать JSON-массив
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

OPENROUTER_API_KEY=
OPENROUTER_MODEL=stepfun/step-3.5-flash:free
OPENROUTER_REFERER=https://py-path.vercel.app
OPENROUTER_TITLE=PyPath
